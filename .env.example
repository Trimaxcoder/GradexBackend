# ── Server ──────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB ─────────────────────────────────────────────
# Local:   mongodb://localhost:27017/cgpa_calculator
# Atlas:   mongodb+srv://<user>:<password>@cluster.mongodb.net/cgpa_calculator
MONGO_URI=mongodb://localhost:27017/cgpa_calculator

# ── JWT ─────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_STRONG_SECRET_KEY_64_CHARS_MINIMUM
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ── Rate Limiting ────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10
